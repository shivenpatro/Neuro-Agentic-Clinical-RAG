# Copy this to .env and fill in values
# Ollama runs at localhost:11434 with an OpenAI-compatible /v1 endpoint
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL_NAME=llama3.2:3b
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=1024

GRAPH_DATA_PATH=./graph/data/symptom_disease.json
LOG_LEVEL=INFO

# FastAPI
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000

# Database (Neon Serverless Postgres)
# Replace with your Neon connection string. Note: Add ?ssl=require if needed
DATABASE_URL=postgresql+asyncpg://user:pass@ep-cool-snowflake-123456.us-east-2.aws.neon.tech/neondb?ssl=require

# Pinecone Vector DB
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_INDEX_NAME=medical-knowledge
PINECONE_ENVIRONMENT=us-east-1

# OpenAI API key for embeddings only (text-embedding-3-small). Required on Render; avoids installing PyTorch.
# Local alternative: omit this and pip install -r requirements-optional.txt for HuggingFace MiniLM (384-dim index).
OPENAI_API_KEY=
