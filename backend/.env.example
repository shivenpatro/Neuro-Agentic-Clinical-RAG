# Copy this to .env and fill in values
# Ollama runs at localhost:11434 with an OpenAI-compatible /v1 endpoint
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL_NAME=llama3.2:3b
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=1024

GRAPH_DATA_PATH=./graph/data/symptom_disease.json
LOG_LEVEL=INFO

# FastAPI
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000
