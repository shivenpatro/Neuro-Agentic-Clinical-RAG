# Copy this to .env and fill in values
#
# Production (Render, etc.): set JWT_SECRET to a long random string — if unset, each restart
# invalidates all tokens and defaults are insecure.
# Ollama runs at localhost:11434 with an OpenAI-compatible /v1 endpoint
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL_NAME=llama3.2:3b
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=1024

GRAPH_DATA_PATH=./graph/data/symptom_disease.json
LOG_LEVEL=INFO

# FastAPI
API_HOST=0.0.0.0
API_PORT=8000
# On Render: do NOT set API_PORT to the literal "$PORT" — Render injects numeric PORT automatically.
CORS_ORIGINS=http://localhost:3000

# Auth — required for stable sessions in production
JWT_SECRET=

# Database (Neon Serverless Postgres)
# Replace with your Neon connection string. Note: Add ?ssl=require if needed
DATABASE_URL=postgresql+asyncpg://user:pass@ep-cool-snowflake-123456.us-east-2.aws.neon.tech/neondb?ssl=require

# RAG: keyword (default, free) | none | pinecone (optional; see requirements-optional-pinecone.txt)
RAG_MODE=keyword

# Pinecone (only if RAG_MODE=pinecone)
PINECONE_API_KEY=
PINECONE_INDEX_NAME=medical-knowledge
PINECONE_ENVIRONMENT=us-east-1

# OpenAI API key — only for optional Pinecone embeddings (text-embedding-3-small), not required for keyword RAG.
OPENAI_API_KEY=
